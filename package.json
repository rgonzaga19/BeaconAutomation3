{
  "name": "beabots",
  "version": "2.0.0",
  "description": "Beabots — Beacon/CF2/SOA automation suite (Electron front end + Python backend)",
  "main": "main.js",
  "author": "Romel Gonzaga",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.beabots.app",
    "productName": "Beabots",
    "icon": "bot.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "config.js",
      "renderer/**/*",
      "node_modules/socket.io-client/**/*"
    ],
    "extraResources": [
      {
        "from": "python-build/server",
        "to": "server"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "bot.ico"
    }
  }
}
